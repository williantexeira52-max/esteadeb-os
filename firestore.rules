rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserEmail() {
      return request.auth.token.email != null ? request.auth.token.email : "";
    }

    function isAdmin() {
      let email = getUserEmail().lower();
      return isAuthenticated() && (
        email == "williantexeira52@gmail.com" ||
        email == "teste@gmail.com" ||
        email == "gestao@esteadeb.com.br" ||
        email == "000000@esteadeb.com.br"
      );
    }

    function isStaff() {
      let email = getUserEmail().lower();
      return isAuthenticated() && (
        isAdmin() || 
        (email.matches(".+@.+") && !email.matches(".+@estudante\\.esteadeb\\.com\\.br$"))
      );
    }

    function isAnyStudent() {
      return isAuthenticated() && getUserEmail().lower().matches(".+@estudante\\.esteadeb\\.com\\.br$");
    }

    function getStudentMatricula() {
      let email = getUserEmail();
      return email.matches(".+@.+") ? email.split("@")[0] : "";
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /school_units/{unitId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isStaff() || request.auth.uid == staffId;
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isStaff() || (isAnyStudent() && resource.data.matricula == getStudentMatricula()) || studentId == request.auth.uid;
      allow list: if isStaff() || (isAnyStudent() && resource.data.matricula == getStudentMatricula());
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /classes/{classId} {
      allow read, list: if isAuthenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read, list: if isAuthenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /modules_history/{modId} {
      allow read, list: if isAuthenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /grades/{gradeId} {
      allow read, list: if isAuthenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /financial_installments/{instId} {
      allow read, list: if isStaff() || (isAnyStudent() && resource.data.studentId == getStudentMatricula());
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /transactions/{id} {
      allow read, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /school_cash/{id} {
      allow read, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /snack_cash/{id} {
      allow read, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Generic match for other collections to prevent breaking
    match /inventory/{id} { allow read, write: if isStaff(); }
    match /requests/{id} { allow read, write: if isAuthenticated(); }
    match /announcements/{id} { allow read, list: if isAuthenticated(); allow write: if isStaff(); }
    match /schedules/{id} { allow read, list: if isAuthenticated(); allow write: if isStaff(); }
    match /curriculum/{id} { allow read, list: if isAuthenticated(); allow write: if isStaff(); }
    match /academic_records/{id} { allow read, list: if isStaff() || (isAnyStudent() && resource.data.studentId == getStudentMatricula()); allow write: if isStaff(); }
    match /subject_enrollments/{id} { allow read, list: if isStaff() || (isAnyStudent() && resource.data.studentId == getStudentMatricula()); allow write: if isStaff(); }
    match /inventory_movements/{id} { allow read, write: if isAuthenticated(); }
    match /app_users/{id} { allow read, write: if isAuthenticated(); }
  }
}
